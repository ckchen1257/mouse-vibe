{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Server",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/mouse-vibe-server/bin/Debug/net10.0/mouse-vibe-server.dll",
      "args": [],
      "cwd": "${workspaceFolder}/mouse-vibe-server",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:8080"
      },
      "preLaunchTask": "build-server",
      "logging": {
        "moduleLoad": false
      }
    },
    {
      "name": "Client Dev Server",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/mouse-vibe-client"
    }
  ],
  "compounds": [
    {
      "name": "Debug Fullstack",
      "configurations": [
        ".NET Server",
        "Client Dev Server"
      ],
      "stopAll": true
    }
  ]
}
